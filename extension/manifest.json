{
  "manifest_version": 3,
  "name": "Rageshake Viewer",
  "version": "1.0.0",
  "description": "Enhances rageshake listing pages with parsed summaries and quick-view buttons for each log file.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*/api/listing/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/api/listing/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "assets/*"],
      "matches": ["https://*/api/listing/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "rageshakes-log-summarizer@manuroe.github.io",
      "strict_min_version": "109.0"
    }
  }
}
