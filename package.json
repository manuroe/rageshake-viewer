{
  "name": "rageshake-viewer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:extension": "tsc -b && vite build --config vite.config.extension.ts && vite build --config vite.config.extension.content.ts",
    "build:extension:firefox": "npm run build:extension && tsx scripts/prepareFirefoxExtension.ts",
    "webext:run": "npm run build:extension:firefox && npx web-ext run --source-dir extension-dist-firefox",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run --environment node --pool forks --minWorkers 1 --maxWorkers 1",
    "pr:comments": "tsx .github/skills/fix-review-comments/fetchPRComments.ts",
    "pr:reply": "tsx .github/skills/fix-review-comments/replyPRComment.ts",
    "pr:reply:batch": "tsx .github/skills/fix-review-comments/replyPRComment.ts --batch-file agent-workspace/pr-replies-template.json",
    "screenshots": "tsx scripts/screenshots.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.18",
    "@visx/axis": "^4.0.1-alpha.0",
    "@visx/brush": "^4.0.1-alpha.0",
    "@visx/event": "^4.0.1-alpha.0",
    "@visx/group": "^4.0.1-alpha.0",
    "@visx/scale": "^4.0.1-alpha.0",
    "@visx/shape": "^4.0.1-alpha.0",
    "@visx/tooltip": "^4.0.1-alpha.0",
    "fflate": "^0.8.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@codspeed/vitest-plugin": "^5.2.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.38",
    "@types/node": "^24.10.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-istanbul": "^3.2.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^25.0.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
